{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build TypeScript",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/resources/ui"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build GuitarFX Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/src/build",
        "--config",
        "Debug",
        "--target",
        "GuitarFX_App"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build GuitarFX App Release",
      "dependsOn": [
        "Build TypeScript"
      ],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/src/build",
        "--config",
        "Release",
        "--target",
        "GuitarFX_App"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build GuitarFX App and VST Release",
      "dependsOn": [
        "Build TypeScript"
      ],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/src/build",
        "--config",
        "Release"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Configure CMake",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-G",
        "Visual Studio 18 2026",
        "-A",
        "x64",
        "-S",
        "${workspaceFolder}/src",
        "-B",
        "${workspaceFolder}/src/build"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Build GuitarFX VST3 Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/src/build",
        "--config",
        "Debug",
        "--target",
        "GuitarFX_VST3"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build VST3DebugHost",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/src/build",
        "--config",
        "Debug",
        "--target",
        "VST3DebugHost"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build VST3 and DebugHost",
      "dependsOn": [
        "Build GuitarFX VST3 Debug",
        "Build VST3DebugHost"
      ],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Build All Tests",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/src/build",
        "--config",
        "Debug"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Run All Tests",
      "type": "shell",
      "command": "ctest",
      "args": [
        "--build-config",
        "Debug",
        "--output-on-failure"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/build"
      },
      "group": "test",
      "problemMatcher": []
    }
  ]
}
