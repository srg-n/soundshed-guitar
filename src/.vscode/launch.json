{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NAMGuitarFX_App (Debug)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/src/platform/app/Debug/NAMGuitarFX.exe",
      "cwd": "${workspaceFolder}/build/src/platform/app/Debug",
      "environment": [
        {
          "name": "NAM_LOG_LEVEL",
